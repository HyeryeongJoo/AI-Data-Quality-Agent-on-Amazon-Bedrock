# =============================================================================
# Bedrock DQ Agent — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# --- AWS ---
AWS_REGION=us-east-1

# --- S3 Buckets ---
S3_STAGING_BUCKET=            # e.g. my-dq-staging-bucket
S3_REPORT_BUCKET=             # e.g. my-dq-reports-bucket
S3_RULES_BUCKET=              # e.g. my-dq-rules-bucket
S3_SAMPLE_KEY=sample/data.jsonl

# --- DynamoDB Tables ---
DYNAMODB_TABLE_NAME=delivery-data-dev
DYNAMODB_STATE_TABLE=dq-agent-state-dev
DYNAMODB_CORRECTION_TABLE=dq-agent-corrections-dev
DYNAMODB_CACHE_TABLE=dq-agent-cache-dev
DYNAMODB_QUARANTINE_TABLE=dq-agent-quarantine-dev

# --- Amazon Bedrock ---
BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-6
AGENT_MODEL_ID=global.anthropic.claude-sonnet-4-6

# --- AgentCore Runtime (leave empty for direct invocation) ---
AGENT_RUNTIME_ARN=

# --- Slack Notifications (optional) ---
SLACK_BOT_TOKEN=              # xoxb-...
SLACK_CHANNEL_ID=

# --- Address API (optional, Korea Juso API) ---
ADDRESS_API_KEY=

# --- Deployment (for deploy.sh) ---
DEPLOY_S3_BUCKET=             # S3 bucket for CloudFormation deployment artifacts
STACK_NAME=bedrock-dq-agent
